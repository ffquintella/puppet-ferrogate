<%- | String[1]              $rust_log,
      String[1]              $cmis_listen,
      Hash[String[1],String] $extra_env,
| -%>
# Managed by Puppet (ferrogate) — do not edit by hand.
# Environment file for the FerroGate CMIS container.
RUST_LOG=<%= $rust_log %>
FERROGATE_LOG_DIR=/opt/ferrogate/logs
CMIS_LISTEN=<%= $cmis_listen %>
CMIS_AUDIT_ROOT=/var/lib/ferrogate/audit
<% $extra_env.each |$k, $v| { -%>
<%= $k %>=<%= $v %>
<% } -%>
